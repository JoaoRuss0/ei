<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_AL_CRUD" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_AL_CRUD">
    <bpmn:participant id="Participant_AL_CRUD" name="ASSET LINK" processRef="AssetLink_CRUD_Management" />
  </bpmn:collaboration>
  <bpmn:process id="AssetLink_CRUD_Management" name="AssetLink_CRUD_Management" isExecutable="true">
    <bpmn:laneSet id="LaneSet_AL_CRUD">
      <bpmn:lane id="Lane_AL_CRUD" name="Initiator">
        <bpmn:flowNodeRef>StartEvent_AL_CRUD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AL_CRUD_Select</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AL_CRUD_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AL_CRUD_Create</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AL_CRUD_Read</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AL_CRUD_Delete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AL_CRUD_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_AL_CRUD_End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_AL_CRUD">
      <bpmn:outgoing>Flow_AL_CRUD_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_AL_CRUD_Select" name="Select Operation">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_CRUD_Management_Asset_Link" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AL_CRUD_1</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_AL_CRUD_Split">
      <bpmn:incoming>Flow_AL_CRUD_2</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_ToRead</bpmn:outgoing>
      <bpmn:outgoing>Flow_AL_CRUD_ToCreate</bpmn:outgoing>
      <bpmn:outgoing>Flow_AL_CRUD_ToDelete</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="Activity_AL_CRUD_Read" name="Read AssetLink">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="AssetLink_Read_Initiator" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AL_CRUD_ToRead</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_FromRead</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Activity_AL_CRUD_Create" name="Create AssetLink">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="AssetLink_Create_Initiator" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AL_CRUD_ToCreate</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_FromCreate</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Activity_AL_CRUD_Delete" name="Delete AssetLink">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="AssetLink_Delete_Initiator" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AL_CRUD_ToDelete</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_FromDelete</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gateway_AL_CRUD_Join">
      <bpmn:incoming>Flow_AL_CRUD_FromRead</bpmn:incoming>
      <bpmn:incoming>Flow_AL_CRUD_FromCreate</bpmn:incoming>
      <bpmn:incoming>Flow_AL_CRUD_FromDelete</bpmn:incoming>
      <bpmn:outgoing>Flow_AL_CRUD_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_AL_CRUD_End">
      <bpmn:incoming>Flow_AL_CRUD_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_AL_CRUD_1" sourceRef="StartEvent_AL_CRUD" targetRef="Activity_AL_CRUD_Select" />
    <bpmn:sequenceFlow id="Flow_AL_CRUD_2" sourceRef="Activity_AL_CRUD_Select" targetRef="Gateway_AL_CRUD_Split" />
    <bpmn:sequenceFlow id="Flow_AL_CRUD_ToRead" sourceRef="Gateway_AL_CRUD_Split" targetRef="Activity_AL_CRUD_Read">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=operation = "READ"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AL_CRUD_ToCreate" sourceRef="Gateway_AL_CRUD_Split" targetRef="Activity_AL_CRUD_Create">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=operation = "CREATE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AL_CRUD_ToDelete" sourceRef="Gateway_AL_CRUD_Split" targetRef="Activity_AL_CRUD_Delete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=operation = "DELETE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AL_CRUD_FromRead" sourceRef="Activity_AL_CRUD_Read" targetRef="Gateway_AL_CRUD_Join" />
    <bpmn:sequenceFlow id="Flow_AL_CRUD_FromCreate" sourceRef="Activity_AL_CRUD_Create" targetRef="Gateway_AL_CRUD_Join" />
    <bpmn:sequenceFlow id="Flow_AL_CRUD_FromDelete" sourceRef="Activity_AL_CRUD_Delete" targetRef="Gateway_AL_CRUD_Join" />
    <bpmn:sequenceFlow id="Flow_AL_CRUD_End" sourceRef="Gateway_AL_CRUD_Join" targetRef="Event_AL_CRUD_End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AL_CRUD">
    <bpmndi:BPMNPlane id="BPMNPlane_AL_CRUD" bpmnElement="Collaboration_AL_CRUD">
      <bpmndi:BPMNShape id="Participant_AL_CRUD_di" bpmnElement="Participant_AL_CRUD" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="710" height="370" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AL_CRUD_di" bpmnElement="Lane_AL_CRUD" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="680" height="370" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_AL_CRUD_di" bpmnElement="StartEvent_AL_CRUD">
        <dc:Bounds x="222" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AL_CRUD_Select_di" bpmnElement="Activity_AL_CRUD_Select">
        <dc:Bounds x="290" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AL_CRUD_Split_di" bpmnElement="Gateway_AL_CRUD_Split" isMarkerVisible="true">
        <dc:Bounds x="425" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AL_CRUD_Read_di" bpmnElement="Activity_AL_CRUD_Read">
        <dc:Bounds x="540" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AL_CRUD_Create_di" bpmnElement="Activity_AL_CRUD_Create">
        <dc:Bounds x="540" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AL_CRUD_Delete_di" bpmnElement="Activity_AL_CRUD_Delete">
        <dc:Bounds x="540" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AL_CRUD_Join_di" bpmnElement="Gateway_AL_CRUD_Join" isMarkerVisible="true">
        <dc:Bounds x="695" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_AL_CRUD_End_di" bpmnElement="Event_AL_CRUD_End">
        <dc:Bounds x="782" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_1_di" bpmnElement="Flow_AL_CRUD_1">
        <di:waypoint x="258" y="210" /><di:waypoint x="290" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_2_di" bpmnElement="Flow_AL_CRUD_2">
        <di:waypoint x="390" y="210" /><di:waypoint x="425" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_ToRead_di" bpmnElement="Flow_AL_CRUD_ToRead">
        <di:waypoint x="450" y="185" /><di:waypoint x="450" y="120" /><di:waypoint x="540" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_ToCreate_di" bpmnElement="Flow_AL_CRUD_ToCreate">
        <di:waypoint x="475" y="210" /><di:waypoint x="540" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_ToDelete_di" bpmnElement="Flow_AL_CRUD_ToDelete">
        <di:waypoint x="450" y="235" /><di:waypoint x="450" y="320" /><di:waypoint x="540" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_FromRead_di" bpmnElement="Flow_AL_CRUD_FromRead">
        <di:waypoint x="640" y="120" /><di:waypoint x="720" y="120" /><di:waypoint x="720" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_FromCreate_di" bpmnElement="Flow_AL_CRUD_FromCreate">
        <di:waypoint x="640" y="210" /><di:waypoint x="695" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_FromDelete_di" bpmnElement="Flow_AL_CRUD_FromDelete">
        <di:waypoint x="640" y="320" /><di:waypoint x="720" y="320" /><di:waypoint x="720" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AL_CRUD_End_di" bpmnElement="Flow_AL_CRUD_End">
        <di:waypoint x="745" y="210" /><di:waypoint x="782" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
