    <bpmn:scriptTask id="Activity_19wv6zo" name="ENERGY_CONSUMED_BY_PROSUMER">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    cons: (for e in telemetryEvents[asset_type = &#34;EV_CHARGER&#34; and Session_Energy != null] return {&#10;      prosumerId: assets[id = e.asset_id][1].prosumerId,&#10;      v: e.Session_Energy&#10;    })[prosumerId != null],&#10;    result: for p in distinct values(cons.prosumerId) return {&#10;      type: &#34;ENERGY_CONSUMED_BY_PROSUMER&#34;,&#10;      entityId: string(p),&#10;      value: sum(cons[prosumerId = p].v),&#10;      timestamp: now()&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
