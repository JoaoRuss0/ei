      "id": "Field_08o72hl"
    },
    {
      "text": "=string join(\n  for p in gridCellList return\n    \"ID: \" + p.id +\n    \"<br/>Address: \" + p.address +\n    \"<br/>Postal Code: \" + p.postalCode +\n    \"<br/>Max Load: \" + string(p.maxLoad) +\n    \"<br/>Operator ID: \" + string(p.operatorId),\n  \"<br/><br/>\"\n)",
      "type": "text",
      "layout": {
        "row": "Row_0ic0w3f",
        "columns": null
      },
      "id": "Field_0jwqjdq"
    }
