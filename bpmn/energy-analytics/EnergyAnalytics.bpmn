    <bpmn:serviceTask id="Activity_0euvo0h" name="Get Telemetry for Assets On Grid Cells" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://{{secrets.KONG_ADDRESS}}:8000/telemetry/Telemetry/by-grid-cell-and-assets?&#34;&#10;+ string join(for a in assets return &#34;assetIds=&#34; + string(a.id), &#34;&#38;&#34;)&#10;+ &#34;&#38;&#34;&#10;+ string join(for c in gridCells return &#34;gridCellIds=&#34; + c.id, &#34;&#38;&#34;)" target="url" />
          <zeebe:input source="={&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusreceivedMessage: response.status,&#10;  telemetryEvents: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0q9u48z</bpmn:incoming>
      <bpmn:outgoing>Flow_18nf70y</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1j4qfui" name="Get Prosumer Assets" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://{{secrets.KONG_ADDRESS}}:8000/asset/Asset/by-prosumer/&#34;+ string(prosumerId)" target="url" />
          <zeebe:input source="={&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;StatusreceivedMessage: response.status,&#10;  assets: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jwpb8u</bpmn:incoming>
      <bpmn:outgoing>Flow_0q9u48z</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0q9u48z" sourceRef="Activity_1j4qfui" targetRef="Activity_0euvo0h" />
    <bpmn:exclusiveGateway id="Gateway_1ozn5de">
      <bpmn:incoming>Flow_18nf70y</bpmn:incoming>
      <bpmn:outgoing>Flow_1bhzm7l</bpmn:outgoing>
      <bpmn:outgoing>Flow_01gp6bj</bpmn:outgoing>
      <bpmn:outgoing>Flow_0usgreo</bpmn:outgoing>
      <bpmn:outgoing>Flow_05i7xdu</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1bhzm7l" sourceRef="Gateway_1ozn5de" targetRef="Activity_0oqkhv3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=analysisType = "ENERGY_DISCHARGED_BY_ZONE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_01gp6bj" sourceRef="Gateway_1ozn5de" targetRef="Activity_171lomj">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=analysisType = "ENERGY_GENERATED_BY_PROSUMER"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0usgreo" sourceRef="Gateway_1ozn5de" targetRef="Activity_19wv6zo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=analysisType = "ENERGY_CONSUMED_BY_PROSUMER"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_05i7xdu" sourceRef="Gateway_1ozn5de" targetRef="Activity_1xg96f8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=analysisType = "AVERAGE_SOC"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:scriptTask id="Activity_0oqkhv3" name="ENERGY_DISCHARGED_BY_ZONE">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    discharge: telemetryEvents[asset_type = &#34;BATTERY&#34; and Current_Output != null and Current_Output &#62; 0],&#10;    result: for z in distinct values(discharge.grid_cell_id) return {&#10;      type: &#34;ENERGY_DISCHARGED_BY_ZONE&#34;,&#10;      entityId: z,&#10;      value: sum(discharge[grid_cell_id = z].Current_Output),&#10;      timestamp: now()&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1bhzm7l</bpmn:incoming>
      <bpmn:outgoing>Flow_0g1zpib</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_171lomj" name="ENERGY_GENERATED_BY_PROSUMER">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    gen: (for e in telemetryEvents[asset_type = &#34;SOLAR&#34; and Daily_Total != null] return {&#10;      prosumerId: assets[id = e.asset_id][1].prosumerId,&#10;      v: e.Daily_Total&#10;    })[prosumerId != null],&#10;    result: for p in distinct values(gen.prosumerId) return {&#10;      type: &#34;ENERGY_GENERATED_BY_PROSUMER&#34;,&#10;      entityId: string(p),&#10;      value: sum(gen[prosumerId = p].v),&#10;      timestamp: now()&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_01gp6bj</bpmn:incoming>
      <bpmn:outgoing>Flow_0j1sk23</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_1xg96f8" name="AVERAGE_SOC">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    soc: telemetryEvents[asset_type = &#34;BATTERY&#34; and State_of_Charge != null],&#10;    result: for z in distinct values(soc.grid_cell_id) return {&#10;      type: &#34;AVERAGE_SOC&#34;,&#10;      entityId: z,&#10;      value: mean(soc[grid_cell_id = z].State_of_Charge),&#10;      timestamp: now()&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_05i7xdu</bpmn:incoming>
      <bpmn:outgoing>Flow_1i6xknt</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_18nf70y" sourceRef="Activity_0euvo0h" targetRef="Gateway_1ozn5de" />
