    <bpmn:scriptTask id="Activity_0oqkhv3" name="Agglomerating energy discharged by zone">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    discharge: (for e in telemetryEvents[asset_type = &#34;BATTERY&#34; and Current_Output != null and Current_Output &#62; 0] return {&#10;      gridCellId: e.grid_cell_id,&#10;      operatorId: gridCells[id = e.grid_cell_id][1].operatorId,&#10;      v: e.Current_Output&#10;    }),&#10;    result: for z in distinct values(discharge.gridCellId) return {&#10;      type: &#34;ENERGY_DISCHARGED_BY_ZONE&#34;,&#10;      utilityOperatorId: discharge[gridCellId = z][1].operatorId,&#10;      utilityOperatorName: utilityOperators[id = discharge[gridCellId = z][1].operatorId][1].name,&#10;      gridCellId: z,&#10;      value: sum(discharge[gridCellId = z].v),&#10;      timestamp: substring(string(now()), 1, 19)&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0recl2z</bpmn:incoming>
      <bpmn:outgoing>Flow_0g1zpib</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_171lomj" name="Agglomerating energy generated by prosumer">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    gen: (for e in telemetryEvents[asset_type = &#34;SOLAR&#34; and Daily_Total != null] return {&#10;      prosumerId: assets[id = e.asset_id][1].prosumerId,&#10;      v: e.Daily_Total&#10;    })[prosumerId != null],&#10;    result: for p in distinct values(gen.prosumerId) return {&#10;      type: &#34;ENERGY_GENERATED_BY_PROSUMER&#34;,&#10;      prosumerId: p,&#10;      prosumerName: prosumers[id = p][1].name,&#10;      value: sum(gen[prosumerId = p].v),&#10;      timestamp: substring(string(now()), 1, 19)&#10;    }&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1onizkm</bpmn:incoming>
      <bpmn:outgoing>Flow_0j1sk23</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_1xg96f8" name="Agglomerating Average State of Charge">
      <bpmn:extensionElements>
        <zeebe:script expression="=(&#10;  {&#10;    soc: telemetryEvents[asset_type = &#34;BATTERY&#34; and State_of_Charge != null],&#10;    result: [&#10;      {&#10;        type: &#34;AVERAGE_SOC&#34;,&#10;        value: mean(soc.State_of_Charge),&#10;        timestamp: substring(string(now()), 1, 19)&#10;      }&#10;    ]&#10;  }&#10;).result" resultVariable="analytics" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_05i7xdu</bpmn:incoming>
      <bpmn:outgoing>Flow_1i6xknt</bpmn:outgoing>
    </bpmn:scriptTask>
