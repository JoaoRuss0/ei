    <bpmn:serviceTask id="Activity_0euvo0h" name="Get Flexibility Events for Prosumer Id" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
