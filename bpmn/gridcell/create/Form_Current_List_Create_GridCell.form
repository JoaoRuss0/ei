{
  "components": [
    {
      "text": "# New",
      "type": "text",
      "layout": {
        "row": "Row_03b91bd",
        "columns": 3
      },
      "id": "Field_0ie3wmp"
    },
    {
      "text": "=\"Name: \" + string(name)  + \"<br/> Max Load: \" + string(maxLoad) +\n\"<br/> Postal Code:\" +   string(postalCode)\n",
      "type": "text",
      "layout": {
        "row": "Row_03b91bd",
        "columns": null
      },
      "id": "Field_06uqaw3"
    },
    {
      "computeOn": "change",
      "type": "expression",
      "layout": {
        "row": "Row_09zgnue",
        "columns": null
      },
      "id": "Field_1es9jx2",
      "key": "repeatingId",
      "expression": "=some p in gridCellList satisfies p.id = id"
    },
    {
      "text": "# All",
      "type": "text",
      "layout": {
        "row": "Row_0vt8ozh",
        "columns": 3
      },
      "id": "Field_1w3q4lm"
    },
    {
      "text": "=string join(\n  for p in gridCellList return\n    \"ID: \" + string(p.id) +\n    \"<br/>Name: \" + p.address +\n    \"<br/>Max Load: \" + string(p.maxLoad) +\n    \"<br/>Postal Code: \" + p.postalCode,\n  \"<br/><br/>\"\n)",
      "type": "text",
      "layout": {
        "row": "Row_0vt8ozh",
        "columns": null
      },
      "id": "Field_1biabvq"
    },
    {
      "text": "Max Load already exists!",
      "type": "text",
      "layout": {
        "row": "Row_0ywdmar",
        "columns": null
      },
      "id": "Field_1gmuiyj",
      "conditional": {
        "hide": "=not(repeatingId)"
      }
    },
    {
      "label": "Checkbox",
      "type": "checkbox",
      "layout": {
        "row": "Row_0ywdmar",
        "columns": 3
      },
      "id": "Field_1bneafl",
      "key": "promise",
      "description": "Allow gridcell creation"
    }
  ],
  "type": "default",
  "id": "Form_Current_List_Create_GridCell",
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
