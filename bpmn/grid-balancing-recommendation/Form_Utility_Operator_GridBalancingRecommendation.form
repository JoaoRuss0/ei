        "columns": null
      },
      "id": "Field_14wei10",
      "key": "gridCellIds",
      "description": "Comma-separated ids: e.g. PORTO_NORTH,LISBON_SOUTH"
    },
    {
      "text": "# Utility Operator",
      "type": "text",
      "layout": {
        "row": "Row_0gjtyul",
        "columns": null
      },
      "id": "Field_1kvgxkl"
    },
    {
      "text": "=    \"ID: \" + string(utilityOperator.id) +\n    \"<br/>Name: \" + utilityOperator.name +\n    \"<br/>IBAN: \" + string(utilityOperator.iban) +\n    \"<br/>Location: \" + utilityOperator.location",
      "type": "text",
      "layout": {
        "row": "Row_1nelt4t",
        "columns": null
      },
      "id": "Field_1413ox1"
    },
    {
      "text": "# Grid Cells",
      "type": "text",
      "layout": {
        "row": "Row_0uh4f4x",
        "columns": null
      },
      "id": "Field_09gl6kl"
    },
    {
      "text": "=string join(\n  for p in gridCells return\n    \"ID: \" + string(p.id) +\n    \"<br/>Name: \" + p.address +\n    \"<br/>Max Load: \" + string(p.maxLoad) +\n    \"<br/>Postal Code: \" + p.postalCode,\n  \"<br/><br/>\"\n)",
      "type": "text",
      "layout": {
        "row": "Row_0vm93te",
        "columns": null
      },
      "id": "Field_0odiy4k"
    }
  ],
  "type": "default",
